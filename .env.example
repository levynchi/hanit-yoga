# Local development – copy to .env and fill in values.
# For Railway deploy: set variables in the service Variables tab (no .env file).

# Django (optional locally; use strong value in production)
DJANGO_SECRET_KEY=your-secret-key-here

# Figma API token for development (export images).
# Copy this file to .env and paste your token after the = sign.
# Get token: Figma → Settings → Security → Personal access tokens.
FIGMA_ACCESS_TOKEN=your_token_here

# --- Railway deploy only (set in dashboard, not in .env) ---
# DJANGO_ENV=production
# DJANGO_SECRET_KEY=...  (generate a strong secret)
# DATABASE_URL is set automatically when you add PostgreSQL.
# RAILWAY_VOLUME_MOUNT_PATH is set automatically when you add a Volume to the app service.
# ALLOWED_HOSTS=optional comma-separated list (default includes .railway.app)
